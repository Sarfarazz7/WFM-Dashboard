# Supabase project settings (Project Settings -> API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — required. API routes use this server-side (never sent to
# the browser) so that uploads/inserts work regardless of RLS policies.
# Project Settings -> API -> "service_role" secret.
SUPABASE_SERVICE_ROLE_KEY=

# Shared login for the 5-person team (see README for how auth works)
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD=

# Random long string used to sign the session cookie. Generate with:
#   openssl rand -base64 32
SESSION_SECRET=

# OpenAI API key for AI Analytics Layer (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Resend API key for email reports (get from https://resend.com/api-keys)
RESEND_API_KEY=

# Secret for cron job authentication (generate with: openssl rand -base64 32)
CRON_SECRET=
